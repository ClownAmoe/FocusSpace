@model FocusSpace.Application.DTOs.TaskDto
@{
    ViewData["Title"] = "Delete Task";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4 border-danger">
            <h4 class="mb-3">⚠️ Delete Task</h4>
            <p class="text-light">Are you sure you want to delete this task? This action cannot be undone.</p>

            <div class="card bg-dark p-3 mb-4">
                <strong class="text-light">@Model.Title</strong>
                @if (Model.Description is not null)
                {
                    <p class="text-light small mb-0 mt-1">@Model.Description</p>
                }
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
