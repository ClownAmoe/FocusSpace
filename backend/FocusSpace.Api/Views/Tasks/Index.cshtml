@model IEnumerable<FocusSpace.Application.DTOs.TaskDto>
@{
    ViewData["Title"] = "My Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">🗂️ My Tasks</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Task</a>
</div>

@if (!Model.Any())
{
    <div class="card p-5 text-center">
        <p class="text-muted mb-3">You have no tasks yet. Create your first one!</p>
        <a asp-action="Create" class="btn btn-primary w-auto mx-auto">Create Task</a>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td class="text-muted">@task.Id</td>
                            <td><strong>@task.Title</strong></td>
                            <td class="text-muted">@(task.Description ?? "—")</td>
                            <td class="text-muted">@task.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@task.Id" class="btn btn-sm btn-outline-secondary me-1">View</a>
                                <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-warning me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@task.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
