@{
    ViewData["Title"] = "Admin Panel";
    Layout = "_AdminLayout";
}

<style>
    body { background-color: #121212; color: #e0e0e0; font-family: Arial; }
    .container { width: 90%; margin: auto; margin-top: 40px; margin-bottom: 40px; }
    h1 { text-align: center; margin-bottom: 30px; font-size: 32px; }
    h2 { font-size: 22px; margin-top: 50px; margin-bottom: 20px; color: #ff9800; }

    .admin-dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .admin-card { background-color: #1e1e1e; padding: 20px; border-radius: 10px; border-left: 4px solid #ff9800; text-align: center; transition: transform 0.3s, box-shadow 0.3s; cursor: pointer; }
    .admin-card:hover { transform: translateY(-5px); box-shadow: 0 0 20px rgba(255,152,0,0.3); }
    .admin-card h3 { margin: 0 0 10px 0; font-size: 13px; color: #999; text-transform: uppercase; letter-spacing: 1px; }
    .admin-card .number { font-size: 40px; font-weight: bold; color: #ff9800; }
    .admin-card.warning .number { color: #f44336; }
    .admin-card.success .number { color: #4caf50; }
    .admin-card.pending .number { color: #2196f3; }

    .info-box { background-color: #1e1e1e; padding: 20px; border-radius: 10px; margin-bottom: 20px; border-left: 4px solid #2196f3; }
    .info-box p { margin: 5px 0; color: #ccc; line-height: 1.6; }

    .btn-group-admin { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 30px; }
    .btn { padding: 10px 18px; border: none; border-radius: 6px; cursor: pointer; text-decoration: none; color: white; font-size: 14px; font-weight: 600; transition: background-color 0.3s; display: inline-block; }
    .btn-secondary { background-color: #607d8b; } .btn-secondary:hover { background-color: #546e7a; }
    .btn-orange { background-color: #ff9800; } .btn-orange:hover { background-color: #f57c00; }
    .btn-danger { background-color: #f44336; } .btn-danger:hover { background-color: #d32f2f; }
    .btn-success { background-color: #4caf50; } .btn-success:hover { background-color: #388e3c; }
    .btn-info { background-color: #2196f3; } .btn-info:hover { background-color: #1565c0; }

    .status-badge { display: inline-block; padding: 4px 9px; border-radius: 5px; font-size: 11px; font-weight: bold; }
    .status-online { background-color: #4caf50; color: white; }

    .footer-info { text-align: center; margin-top: 50px; padding-top: 20px; border-top: 1px solid #333; color: #999; font-size: 12px; }

    /* Modal */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.7); z-index: 1000; justify-content: center; align-items: center; }
    .modal-overlay.active { display: flex; }
    .modal-content { background-color: #1e1e1e; border-radius: 10px; width: 90%; max-width: 750px; max-height: 80vh; overflow-y: auto; border: 2px solid #ff9800; box-shadow: 0 0 30px rgba(255,152,0,0.3); }
    .modal-header { padding: 20px; border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: center; }
    .modal-header h2 { margin: 0; font-size: 22px; color: #ff9800; }
    .modal-close { background: none; border: none; color: #999; font-size: 28px; cursor: pointer; }
    .modal-close:hover { color: #fff; }
    .modal-body { padding: 20px; }

    /* Tabs */
    .tab-buttons { display: flex; gap: 10px; margin-bottom: 20px; }
    .tab-btn { padding: 8px 16px; border: 1px solid #444; border-radius: 6px; background: #2a2a2a; color: #ccc; cursor: pointer; font-size: 13px; transition: all 0.2s; }
    .tab-btn.active { background: #ff9800; color: #000; border-color: #ff9800; font-weight: bold; }

    /* User items */
    .user-item { background-color: #252525; padding: 15px; margin-bottom: 10px; border-radius: 8px; display: flex; justify-content: space-between; align-items: flex-start; border-left: 4px solid #4caf50; }
    .user-item.blocked { border-left-color: #f44336; opacity: 0.7; }
    .user-item.pending-approval { border-left-color: #2196f3; }
    .user-info { flex: 1; }
    .user-name { font-weight: bold; color: #e0e0e0; font-size: 15px; }
    .user-email { color: #999; font-size: 13px; margin-top: 4px; }
    .user-details { color: #777; font-size: 12px; margin-top: 4px; }
    .user-status { margin-top: 6px; display: flex; gap: 6px; flex-wrap: wrap; }
    .user-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-left: 12px; }
    .btn-small { padding: 7px 11px; font-size: 12px; }
    .loading { text-align: center; padding: 50px; color: #999; }
</style>

<div class="container">
    <h1>⚙️ Admin Panel</h1>

    <div class="admin-dashboard">
        <div class="admin-card success" onclick="openModal('all')">
            <h3>Total Users</h3>
            <div class="number">@ViewBag.TotalUsers</div>
        </div>
        <div class="admin-card pending" onclick="openModal('pending')">
            <h3>Pending Approval</h3>
            <div class="number">@ViewBag.PendingApproval</div>
        </div>
        <div class="admin-card">
            <h3>Active Tasks</h3>
            <div class="number">@ViewBag.ActiveTasks</div>
        </div>
        <div class="admin-card success">
            <h3>Active Sessions</h3>
            <div class="number">@ViewBag.ActiveSessions</div>
        </div>
        <div class="admin-card @(ViewBag.BlockedUsers > 0 ? "warning" : "")">
            <h3>Blocked Users</h3>
            <div class="number">@ViewBag.BlockedUsers</div>
        </div>
    </div>

    <div class="info-box">
        <h2 style="margin-top:0">📊 System Overview</h2>
        <p><strong>Status:</strong> <span class="status-badge status-online">Online</span></p>
        <p><strong>Database:</strong> PostgreSQL (Connected)</p>
        <p><strong>Auth:</strong> ASP.NET Core Identity + Cookie</p>
        <p><strong>Admin:</strong> @User.Identity?.Name</p>
        <p><strong>Last Updated:</strong> @DateTime.UtcNow.ToString("dd MMM yyyy HH:mm:ss") UTC</p>
    </div>

    <h2>🔧 Management</h2>
    <div class="btn-group-admin">
        <button class="btn btn-orange" onclick="openModal('all')">Manage Users</button>
        <button class="btn btn-info" onclick="openModal('pending')">
            Pending (@ViewBag.PendingApproval)
        </button>
        <a href="/Tasks" class="btn btn-secondary">View Tasks</a>
    </div>

    <div class="footer-info">
        <p>FocusSpace Admin Panel © 2026</p>
    </div>
</div>

<!-- Users Modal -->
<div class="modal-overlay" id="usersModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>👥 Manage Users</h2>
            <button class="modal-close" onclick="closeModal()">×</button>
        </div>
        <div class="modal-body">
            <div class="tab-buttons">
                <button class="tab-btn active" id="tab-all"     onclick="setTab('all')">All Users</button>
                <button class="tab-btn"         id="tab-pending" onclick="setTab('pending')">Pending</button>
                <button class="tab-btn"         id="tab-blocked" onclick="setTab('blocked')">Blocked</button>
            </div>
            <div id="usersContainer">
                <div class="loading">Loading…</div>
            </div>
        </div>
    </div>
</div>

@* Прихований antiforgery токен для fetch-запитів *@
<form id="af-form" style="display:none">
    @Html.AntiForgeryToken()
</form>

<script>
    let allUsers = [];
    let currentTab = 'all';

    function getToken() {
        return document.querySelector('#af-form input[name="__RequestVerificationToken"]')?.value ?? '';
    }

    function openModal(tab) {
        currentTab = tab || 'all';
        document.getElementById('usersModal').classList.add('active');
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + currentTab).classList.add('active');
        loadUsers();
    }

    function closeModal() {
        document.getElementById('usersModal').classList.remove('active');
    }

    function setTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + tab).classList.add('active');
        renderUsers();
    }

    function loadUsers() {
        fetch('/Admin/GetUsers')
            .then(r => r.json())
            .then(users => { allUsers = users; renderUsers(); })
            .catch(() => {
                document.getElementById('usersContainer').innerHTML =
                    '<p style="text-align:center;color:#f44336">Error loading users.</p>';
            });
    }

    function renderUsers() {
        let list = allUsers;
        if (currentTab === 'pending') list = allUsers.filter(u => !u.isApproved && u.emailConfirmed);
        if (currentTab === 'blocked') list = allUsers.filter(u => u.isBlocked);

        const container = document.getElementById('usersContainer');

        if (list.length === 0) {
            container.innerHTML = '<p style="text-align:center;color:#999">No users in this category.</p>';
            return;
        }

        container.innerHTML = list.map(u => {
            const rowClass = u.isBlocked ? 'blocked' : (!u.isApproved && u.emailConfirmed ? 'pending-approval' : '');

            const badges = [
                u.isBlocked ? '<span style="color:#f44336;font-size:11px;font-weight:bold">BLOCKED</span>' : '',
                (!u.isApproved && u.emailConfirmed) ? '<span style="color:#2196f3;font-size:11px;font-weight:bold">PENDING</span>' : '',
                !u.emailConfirmed ? '<span style="color:#888;font-size:11px;font-weight:bold">UNCONFIRMED</span>' : '',
            ].filter(Boolean).join(' &nbsp;');

            const approveBtn = (!u.isApproved && u.emailConfirmed)
                ? `<button class="btn btn-small btn-success" onclick="approveUser(${u.id})">Approve</button>` : '';

            const blockBtn = u.isBlocked
                ? `<button class="btn btn-small btn-orange" onclick="unblockUser(${u.id})">Unblock</button>`
                : `<button class="btn btn-small btn-danger" onclick="blockUser(${u.id})">Block</button>`;

            const promoteBtn = `<button class="btn btn-small btn-info" onclick="promoteToAdmin(${u.id})" title="Promote to Admin">Make Admin</button>`;

            return `
                <div class="user-item ${rowClass}" id="row-${u.id}">
                    <div class="user-info">
                        <div class="user-name">${u.username}</div>
                        <div class="user-email">${u.email}</div>
                        <div class="user-details">
                            Tasks: ${u.taskCount} &nbsp;|&nbsp;
                            Sessions: ${u.sessionCount} &nbsp;|&nbsp;
                            Joined: ${new Date(u.createdAt).toLocaleDateString()}
                        </div>
                        <div class="user-status">${badges}</div>
                    </div>
                    <div class="user-actions">
                        ${approveBtn}
                        ${blockBtn}
                        ${promoteBtn}
                    </div>
                </div>`;
        }).join('');
    }

    async function approveUser(id) {
        if (!confirm('Approve this user?')) return;
        const r = await fetch(`/Admin/ApproveUser/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        const d = await r.json();
        alert(d.message);
        loadUsers();
    }

    async function blockUser(id) {
        if (!confirm('Block this user?')) return;
        const r = await fetch(`/Admin/BlockUser/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        const d = await r.json();
        alert(d.message);
        loadUsers();
    }

    async function unblockUser(id) {
        if (!confirm('Unblock this user?')) return;
        const r = await fetch(`/Admin/UnblockUser/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        const d = await r.json();
        alert(d.message);
        loadUsers();
    }

    async function promoteToAdmin(id) {
        if (!confirm('Promote this user to Admin? This grants full admin access.')) return;
        const r = await fetch(`/Admin/PromoteToAdmin/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        const d = await r.json();
        alert(d.message);
        loadUsers();
    }

    document.getElementById('usersModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });
</script>