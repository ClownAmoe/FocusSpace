@using FocusSpace.Api
@{
    ViewData["Title"] = "Admin Panel";
    Layout = "_AdminLayout";
}

<style>
    body {
        background-color: #121212;
        color: #e0e0e0;
        font-family: Arial;
    }

    .container {
        width: 90%;
        margin: auto;
        margin-top: 40px;
        margin-bottom: 40px;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        font-size: 32px;
    }

    h2 {
        font-size: 22px;
        margin-top: 50px;
        margin-bottom: 20px;
        color: #ff9800;
    }

    .admin-dashboard {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .admin-card {
        background-color: #1e1e1e;
        padding: 20px;
        border-radius: 10px;
        border-left: 4px solid #ff9800;
        text-align: center;
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }

    .admin-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0 20px rgba(255, 152, 0, 0.3);
    }

    .admin-card h3 {
        margin: 0 0 10px 0;
        font-size: 16px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .admin-card .number {
        font-size: 40px;
        font-weight: bold;
        color: #ff9800;
    }

    .admin-card.warning .number {
        color: #f44336;
    }

    .admin-card.success .number {
        color: #4caf50;
    }

    .info-box {
        background-color: #1e1e1e;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        border-left: 4px solid #2196f3;
    }

    .info-box p {
        margin: 5px 0;
        color: #ccc;
        line-height: 1.6;
    }

    .btn-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 30px;
    }

    .btn {
        padding: 12px 20px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        color: white;
        font-size: 14px;
        font-weight: 600;
        transition: background-color 0.3s;
        display: inline-block;
    }

    .btn-secondary {
        background-color: #607d8b;
    }

    .btn-secondary:hover {
        background-color: #546e7a;
    }

    .btn-primary {
        background-color: #ff9800;
    }

    .btn-primary:hover {
        background-color: #f57c00;
    }

    .btn-danger {
        background-color: #f44336;
    }

    .btn-danger:hover {
        background-color: #d32f2f;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 12px;
        font-weight: bold;
    }

    .status-online {
        background-color: #4caf50;
        color: white;
    }

    .status-warning {
        background-color: #ff9800;
        color: white;
    }

    .footer-info {
        text-align: center;
        margin-top: 50px;
        padding-top: 20px;
        border-top: 1px solid #333;
        color: #999;
        font-size: 12px;
    }

  
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.7);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .modal-overlay.active {
        display: flex;
    }

    .modal-content {
        background-color: #1e1e1e;
        border-radius: 10px;
        width: 90%;
        max-width: 700px;
        max-height: 80vh;
        overflow-y: auto;
        border: 2px solid #ff9800;
        box-shadow: 0 0 30px rgba(255, 152, 0, 0.3);
    }

    .modal-header {
        padding: 20px;
        border-bottom: 1px solid #333;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-header h2 {
        margin: 0;
        font-size: 24px;
        color: #ff9800;
    }

    .modal-close {
        background: none;
        border: none;
        color: #999;
        font-size: 28px;
        cursor: pointer;
        transition: color 0.3s;
    }

    .modal-close:hover {
        color: #fff;
    }

    .modal-body {
        padding: 20px;
    }

    .user-item {
        background-color: #252525;
        padding: 15px;
        margin-bottom: 10px;
        border-radius: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-left: 4px solid #4caf50;
    }

    .user-item.blocked {
        border-left-color: #f44336;
        opacity: 0.7;
    }

    .user-info {
        flex: 1;
    }

    .user-name {
        font-weight: bold;
        color: #e0e0e0;
        font-size: 16px;
    }

    .user-email {
        color: #999;
        font-size: 13px;
        margin-top: 5px;
    }

    .user-details {
        color: #777;
        font-size: 12px;
        margin-top: 5px;
    }

    .user-actions {
        display: flex;
        gap: 10px;
    }

    .btn-small {
        padding: 8px 12px;
        font-size: 12px;
    }

    .loading {
        text-align: center;
        padding: 50px;
        color: #999;
    }

    .loading::after {
        content: "...";
        animation: dots 1.5s infinite;
    }
</style>

<div class="container">
    <h1>⚙️ Admin Panel</h1>

    <div class="admin-dashboard">
        <div class="admin-card success" onclick="openUsersModal()">
            <h3>Total Users</h3>
            <div class="number">@ViewBag.TotalUsers</div>
        </div>
        <div class="admin-card">
            <h3>Active Tasks</h3>
            <div class="number">@ViewBag.ActiveTasks</div>
        </div>
        <div class="admin-card success">
            <h3>Active Sessions</h3>
            <div class="number">@ViewBag.ActiveSessions</div>
        </div>
        <div class="admin-card @(ViewBag.BlockedUsers > 0 ? "warning" : "")">
            <h3>Blocked Users</h3>
            <div class="number">@ViewBag.BlockedUsers</div>
        </div>
    </div>

    <div class="info-box">
        <h2 style="margin-top: 0;">📊 System Overview</h2>
        <p><strong>Status:</strong> <span class="status-badge status-online">✓ Online</span></p>
        <p><strong>Database:</strong> PostgreSQL (Connected)</p>
        <p><strong>Environment:</strong> Development</p>
        <p><strong>Last Updated:</strong> @DateTime.UtcNow.ToString("dd MMM yyyy HH:mm:ss UTC")</p>
    </div>

    <h2>🔧 System Management</h2>
    <p style="color: #999; margin-bottom: 20px;">Welcome to the FocusSpace Admin Panel. Here you can manage system resources and monitor application health.</p>
    
    <div class="btn-group">
        <a href="/tasks" class="btn btn-secondary">View All Tasks</a>
        <a href="/" class="btn btn-secondary">Back to Home</a>
    </div>

    <div class="footer-info">
        <p>FocusSpace Admin Panel • All rights reserved © 2026</p>
    </div>
</div>


<div class="modal-overlay" id="usersModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>👥 Manage Users</h2>
            <button class="modal-close" onclick="closeUsersModal()">×</button>
        </div>
        <div class="modal-body" id="usersListContainer">
            <div class="loading">Loading users</div>
        </div>
    </div>
</div>

<script>
    function openUsersModal() {
        document.getElementById('usersModal').classList.add('active');
        loadUsers();
    }

    function closeUsersModal() {
        document.getElementById('usersModal').classList.remove('active');
    }

    function loadUsers() {
        const container = document.getElementById('usersListContainer');
        
        fetch('/Admin/GetUsers')
            .then(response => response.json())
            .then(users => {
                if (users.length === 0) {
                    container.innerHTML = '<p style="text-align: center; color: #999;">No users found</p>';
                    return;
                }

                let html = '';
                users.forEach(user => {
                    const blockedClass = user.isBlocked ? 'blocked' : '';
                    const buttonText = user.isBlocked ? 'Unblock' : 'Block';
                    const buttonColor = user.isBlocked ? 'btn-primary' : 'btn-danger';
                    const actionMethod = user.isBlocked ? 'unblockUser' : 'blockUser';
                    
                    html += `
                        <div class="user-item ${blockedClass}">
                            <div class="user-info">
                                <div class="user-name">${user.username}</div>
                                <div class="user-email">${user.email}</div>
                                <div class="user-details">
                                    Tasks: ${user.taskCount} | Sessions: ${user.sessionCount} | Joined: ${new Date(user.createdAt).toLocaleDateString()}
                                </div>
                            </div>
                            <div class="user-actions">
                                ${user.isBlocked ? '<span style="color: #f44336; font-weight: bold;">🚫 BLOCKED</span>' : ''}
                                <button class="btn btn-small ${buttonColor}" onclick="${actionMethod}(${user.id}, this)">${buttonText}</button>
                            </div>
                        </div>
                    `;
                });
                
                container.innerHTML = html;
            })
            .catch(error => {
                console.error('Error loading users:', error);
                container.innerHTML = '<p style="text-align: center; color: #f44336;">Error loading users</p>';
            });
    }

    function blockUser(userId, button) {
        if (!confirm('Are you sure you want to block this user?')) return;
        
        fetch(`/Admin/BlockUser/${userId}`, { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                alert('User blocked successfully');
                loadUsers();
            })
            .catch(error => {
                console.error('Error blocking user:', error);
                alert('Error blocking user');
            });
    }

    function unblockUser(userId, button) {
        if (!confirm('Are you sure you want to unblock this user?')) return;
        
        fetch(`/Admin/UnblockUser/${userId}`, { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                alert('User unblocked successfully');
                loadUsers();
            })
            .catch(error => {
                console.error('Error unblocking user:', error);
                alert('Error unblocking user');
            });
    }


    document.getElementById('usersModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeUsersModal();
        }
    });
</script>
