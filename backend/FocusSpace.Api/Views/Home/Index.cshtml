@{
    ViewData["Title"] = "FocusSpace";
}
@model List<FocusSpace.Domain.Entities.Planet>
@using System.Globalization

@{
    var planets = (Model ?? new List<FocusSpace.Domain.Entities.Planet>())
        .OrderBy(p => p.OrderNumber)
        .ToList();

    const double centerX = 510;
    const double centerY = 360;

    var minOrbit = 145d;
    var maxOrbit = 300d;
    var orbitStep = planets.Count > 1
        ? (maxOrbit - minOrbit) / (planets.Count - 1)
        : 0d;

    var colorPairs = new[]
    {
        ("#b8b8b8", "#6d6d6d"),
        ("#ffd784", "#efab3a"),
        ("#91d8ff", "#2275d9"),
        ("#f6a27f", "#c0501e"),
        ("#d4a06a", "#8f6038"),
        ("#f2d9aa", "#c49a67"),
        ("#87f0ff", "#2db2c6"),
        ("#7594ff", "#2f4ab8")
    };

    double GetPlanetSize(int index)
    {
        var sizes = new[] { 11d, 16d, 20d, 14d, 30d, 24d, 18d, 18d };
        if (index < sizes.Length) return sizes[index];
        return 14d + (index % 5) * 2d;
    }

    string GetPlanetType(string name)
    {
        var n = (name ?? string.Empty).Trim().ToLowerInvariant();
        if (n is "mercury" or "venus" or "earth" or "mars") return "Rocky";
        if (n is "jupiter" or "saturn") return "Gas Giant";
        if (n is "uranus" or "neptune") return "Ice Giant";
        return "Exoplanet";
    }

    string GetTypeClass(string type)
    {
        return type switch
        {
            "Rocky" => "type-rocky",
            "Gas Giant" => "type-gas",
            "Ice Giant" => "type-ice",
            _ => "type-exo"
        };
    }

    (double x, double y) GetPoint(double orbitRadius, double angleDeg)
    {
        var angleRad = Math.PI * angleDeg / 180.0;
        return (
            centerX + orbitRadius * Math.Cos(angleRad),
            centerY + orbitRadius * Math.Sin(angleRad)
        );
    }
}

<form id="af-form" style="display:none">
    @Html.AntiForgeryToken()
</form>

<div class="space-stage">
    <svg id="planet-visualization"
         width="100%"
         height="100%"
         viewBox="0 0 1020 820"
         preserveAspectRatio="xMidYMid meet"
         data-center-x="510"
         data-center-y="360">

        <defs>
            @for (var i = 0; i < planets.Count; i++)
            {
                var pair = colorPairs[i % colorPairs.Length];
                <radialGradient id="planetGradient-@i" cx="35%" cy="35%">
                    <stop offset="0%" style="stop-color:@pair.Item1;stop-opacity:1" />
                    <stop offset="100%" style="stop-color:@pair.Item2;stop-opacity:1" />
                </radialGradient>
            }
            <radialGradient id="sunGradient" cx="40%" cy="40%">
                <stop offset="0%" style="stop-color:#fdb813;stop-opacity:1" />
                <stop offset="70%" style="stop-color:#fdb813;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#fd8813;stop-opacity:1" />
            </radialGradient>
        </defs>

        @for (var i = 0; i < planets.Count; i++)
        {
            var orbit = minOrbit + i * orbitStep;
            var opacity = Math.Max(0.12, 0.34 - i * 0.03);
            <circle cx="@centerX"
                    cy="@centerY"
                    r="@orbit.ToString("0.###", CultureInfo.InvariantCulture)"
                    fill="none"
                    stroke="#7c3aed"
                    stroke-width="1"
                    opacity="@opacity.ToString("0.###", CultureInfo.InvariantCulture)" />
        }

        <circle cx="@centerX" cy="@centerY" r="50" fill="url(#sunGradient)" />
        <circle cx="@centerX" cy="@centerY" r="50" fill="#000" opacity="0.1" />

        <g id="planets-orbit" style="animation: rotate 70s linear infinite; transform-origin: 510px 360px;">
            @for (var i = 0; i < planets.Count; i++)
            {
                var planet = planets[i];
                var orbit = minOrbit + i * orbitStep;
                var angle = planets.Count == 1 ? -90d : -90d + (360d / planets.Count) * i;
                var point = GetPoint(orbit, angle);
                var size = GetPlanetSize(i);
                var type = GetPlanetType(planet.Name);
                var typeClass = GetTypeClass(type);
                var cx = point.x.ToString("0.###", CultureInfo.InvariantCulture);
                var cy = point.y.ToString("0.###", CultureInfo.InvariantCulture);
                var radius = size.ToString("0.###", CultureInfo.InvariantCulture);
                var desc = planet.Description ?? string.Empty;
                var distance = planet.DistanceFromPrevious?.ToString() ?? string.Empty;
                <g class="planet @typeClass"
                   data-id="@planet.Id"
                   data-name="@planet.Name"
                   data-type="@type"
                   data-order="@planet.OrderNumber"
                   data-description="@desc"
                   data-distance="@distance"
                   data-cx="@cx"
                   data-cy="@cy"
                   data-radius="@radius"
                   tabindex="0"
                   role="button"
                   aria-label="Planet @planet.Name">
                    <circle cx="@cx" cy="@cy" r="@radius" fill="url(#planetGradient-@i)" />
                    <circle cx="@cx" cy="@cy" r="@radius" fill="#000" opacity="0.15" />
                    @if (type == "Rocky")
                    {
                        <circle cx="@(point.x - size * 0.25)" cy="@(point.y - size * 0.18)" r="@(Math.Max(1d, size * 0.12))" fill="#2c2c2c" opacity="0.45" />
                        <circle cx="@(point.x + size * 0.18)" cy="@(point.y + size * 0.12)" r="@(Math.Max(1d, size * 0.09))" fill="#2c2c2c" opacity="0.4" />
                        <circle cx="@(point.x + size * 0.05)" cy="@(point.y - size * 0.28)" r="@(Math.Max(1d, size * 0.07))" fill="#f1e3bf" opacity="0.35" />
                    }
                    else if (type == "Gas Giant")
                    {
                        <ellipse cx="@cx"
                                 cy="@cy"
                                 rx="@(size * 1.68)"
                                 ry="@(Math.Max(5d, size * 0.42))"
                                 fill="none"
                                 stroke="#f1d1a0"
                                 stroke-width="2"
                                 opacity="0.5" />
                        <ellipse cx="@cx"
                                 cy="@cy"
                                 rx="@(size * 0.95)"
                                 ry="@(Math.Max(2d, size * 0.14))"
                                 fill="#ffffff"
                                 opacity="0.10" />
                    }
                    else if (type == "Ice Giant")
                    {
                        <ellipse cx="@cx"
                                 cy="@cy"
                                 rx="@(size * 0.8)"
                                 ry="@(size * 0.38)"
                                 fill="none"
                                 stroke="#d7fbff"
                                 stroke-width="1.5"
                                 opacity="0.45"
                                 transform="rotate(-25 @cx @cy)" />
                        <circle cx="@(point.x + size * 0.18)" cy="@(point.y - size * 0.08)" r="@(Math.Max(1d, size * 0.07))" fill="#f8ffff" opacity="0.5" />
                    }
                    else
                    {
                        <circle cx="@cx" cy="@cy" r="@(Math.Max(2d, size * 0.12))" fill="#ffffff" opacity="0.2" />
                    }
                </g>
            }
        </g>

        <g id="rocket" transform="translate(550, 120)">
            <g fill="lightgray" fill-rule="evenodd" stroke="black" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" transform="translate(4 1)">
                <path d="m6.5 18.5c3-2.5021966 4-5.5021966 4-9 0-3.49780342-1-6.49780342-4-9-3 2.50219658-4 5.50219658-4 9 0 3.4978034 1 6.4978034 4 9z"/>
                <path fill="red" d="m10.0620355 13.3616971c.4244504.2452152.814833.5459803 1.1711478.9022951 1.1190122 1.1190122 1.6901459 2.5740294 1.7134011 4.3650515-2.5082701-.109848-3.88207621-.7645704-4.92553235-1.6471655m-5.11545113-3.6201811c-.42445038.2452152-.81483298.5459803-1.17114781.9022951-1.11901221 1.1190122-1.6901459 2.5740294-1.71340106 4.3650515 2.50827003-.109848 3.88207616-.7645704 4.9255323-1.6471655"/>
                <circle cx="6.5" cy="6.5" r="2" fill="cyan"/>
            </g>
        </g>
    </svg>

    <aside id="planet-info" class="planet-info">
        <div class="planet-panel-head">
            <h4 id="planet-info-name" class="planet-panel-title">Choose a Planet</h4>
            <button id="close-planet-panel" class="planet-panel-close" type="button" aria-label="Close">×</button>
        </div>
        <p id="planet-info-type" class="planet-info-type"></p>
        <p id="planet-info-description" class="planet-info-description"></p>
        <p id="planet-info-distance" class="planet-info-distance"></p>

        <div id="planet-actions" class="planet-actions hidden">
            <div class="planet-actions-title">Timer</div>
            <label class="planet-actions-label" for="planet-task-minutes">Minutes</label>
            <input id="planet-task-minutes" class="planet-actions-input" type="number" min="1" max="300" value="25" />
            <button id="planet-start-session" class="planet-action-btn" type="button">Start timer</button>
            <p id="planet-actions-note" class="planet-actions-note"></p>
        </div>
    </aside>

    <div id="planet-tooltip" class="planet-tooltip" aria-hidden="true"></div>
</div>

<div class="container mt-4 mb-4">
    <div class="d-flex justify-content-center mb-3">
        <a href="/Session" class="btn btn-outline-info" id="openFocusTimerBtn">Open Focus Timer</a>
    </div>
    <h3 class="text-center mb-4">Available Planets</h3>
    @if (Model is not null && Model.Any())
    {
        <div class="row g-3">
            @foreach (var planet in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 bg-dark text-light border-secondary">
                        <div class="card-body">
                            <h5 class="card-title">#@planet.OrderNumber @planet.Name</h5>
                            <p class="card-text text-secondary mb-2">
                                @(string.IsNullOrWhiteSpace(planet.Description) ? "No description" : planet.Description)
                            </p>
                            @if (planet.DistanceFromPrevious.HasValue)
                            {
                                <div class="small text-info">Distance: @planet.DistanceFromPrevious</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-center text-muted">No planets found.</p>
    }
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="text-center mt-4">
        <h2 class="mb-3">Welcome to FocusSpace</h2>
        <p class="text-muted mb-4">Track your focus sessions and explore the galaxy of productivity.</p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                Get Started
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                Log In
            </a>
        </div>
    </div>
}

<style>
    .space-stage {
        position: relative;
        width: min(1080px, 96vw);
        height: min(76vh, 740px);
        min-height: 520px;
        margin: 86px auto 0;
        border-radius: 16px;
        overflow: hidden;
        background:
            radial-gradient(circle at 20% 20%, rgba(125, 58, 237, 0.18), transparent 40%),
            radial-gradient(circle at 80% 80%, rgba(0, 173, 181, 0.14), transparent 45%),
            linear-gradient(180deg, #0e0f1a 0%, #14172a 100%);
        border: 1px solid rgba(124, 58, 237, 0.28);
    }

    #planet-visualization {
        display: block;
        width: 100%;
        height: 100%;
    }

    .planet {
        cursor: pointer;
        transition: transform 0.25s ease;
    }

    .planet circle {
        transition: stroke 0.2s ease, stroke-width 0.2s ease, filter 0.2s ease;
    }

    .planet:hover circle,
    .planet.selected circle,
    .planet:focus-visible circle {
        stroke: #ffffff;
        stroke-width: 2;
        filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.45));
    }

    .planet.type-rocky circle:first-child {
        stroke: rgba(230, 220, 185, 0.4);
        stroke-width: 0.8;
    }

    .planet.type-gas circle:first-child {
        stroke: rgba(250, 201, 112, 0.55);
        stroke-width: 1;
    }

    .planet.type-ice circle:first-child {
        stroke: rgba(126, 217, 255, 0.55);
        stroke-width: 1;
    }

    .planet.type-exo circle:first-child {
        stroke: rgba(186, 162, 255, 0.55);
        stroke-width: 1;
    }

    .planet-info {
        position: absolute;
        right: 14px;
        bottom: 14px;
        width: min(340px, calc(100% - 28px));
        max-height: calc(100% - 28px);
        background: rgba(12, 16, 30, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 12px;
        padding: 16px;
        color: #f0f2ff;
        backdrop-filter: blur(8px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        overflow-y: auto;
        transition: all 0.3s ease;
    }

    .planet-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 6px;
    }

    .planet-panel-title {
        margin: 0;
        font-size: 18px;
        color: #f2e9ff;
    }

    .planet-panel-close {
        background: none;
        border: none;
        color: #9aa0b6;
        font-size: 18px;
        cursor: pointer;
        padding: 0;
        display: none;
    }

    .planet-info h4 {
        margin: 0 0 6px;
        font-size: 18px;
    }

    .planet-info-type {
        margin: 0 0 8px;
        color: #ffd98e;
        font-weight: 600;
    }

    .planet-info-description {
        margin: 0 0 8px;
        color: #d6d9f0;
        font-size: 14px;
        line-height: 1.35;
    }

    .planet-info-distance {
        margin: 0;
        color: #8edcff;
        font-size: 13px;
    }

    .planet-actions {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .planet-actions.hidden {
        display: none;
    }

    .planet-actions-title {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: #b9c2ff;
        margin-bottom: 8px;
    }

    .planet-actions-label {
        display: block;
        font-size: 11px;
        color: #9aa0b6;
        margin-bottom: 4px;
    }

    .planet-actions-input {
        width: 100%;
        padding: 8px 10px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(10, 12, 24, 0.6);
        color: #f0f2ff;
        margin-bottom: 8px;
        font-size: 13px;
    }

    .planet-action-btn {
        width: 100%;
        padding: 9px 10px;
        border-radius: 8px;
        border: 1px solid transparent;
        background: #2f7bf6;
        color: #ffffff;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }

    .planet-action-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
    }

    .planet-actions-note {
        margin: 8px 0 0;
        font-size: 11px;
        color: #8edcff;
        min-height: 14px;
    }

    .planet-tooltip {
        position: absolute;
        pointer-events: none;
        z-index: 5;
        display: none;
        max-width: 220px;
        background: rgba(7, 10, 20, 0.92);
        color: #f5f7ff;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 10px;
        padding: 10px 12px;
        box-shadow: 0 16px 32px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(8px);
        font-size: 13px;
        line-height: 1.35;
    }

    .planet-tooltip strong {
        display: block;
        font-size: 14px;
        margin-bottom: 4px;
        color: #ffd98e;
    }

    .planet-tooltip .tooltip-meta {
        color: #9fdcff;
        margin-top: 6px;
    }

    @@media (max-width: 768px) {
        .space-stage {
            margin-top: 74px;
            min-height: 440px;
            height: 68vh;
        }

        .planet-info {
            position: static;
            width: calc(100% - 24px);
            margin: 12px;
        }
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>

@section Scripts {
    <script>
        const rocket = document.getElementById('rocket');
        const planetsOrbit = document.getElementById('planets-orbit');
        const planetNodes = Array.from(document.querySelectorAll('.planet'));
        const svgElement = document.getElementById('planet-visualization');
        const centerX = parseFloat(svgElement.dataset.centerX || '510');
        const centerY = parseFloat(svgElement.dataset.centerY || '360');
        const spaceStage = document.querySelector('.space-stage');
        const planetTooltip = document.getElementById('planet-tooltip');
        const defaultViewBox = { x: 0, y: 0, width: 1020, height: 820 };

        const infoName = document.getElementById('planet-info-name');
        const infoType = document.getElementById('planet-info-type');
        const infoDescription = document.getElementById('planet-info-description');
        const infoDistance = document.getElementById('planet-info-distance');
        const closePlanetPanel = document.getElementById('close-planet-panel');
        const planetActions = document.getElementById('planet-actions');
        const taskMinutesInput = document.getElementById('planet-task-minutes');
        const startSessionButton = document.getElementById('planet-start-session');
        const actionsNote = document.getElementById('planet-actions-note');
        const isAuthenticated = @((User.Identity?.IsAuthenticated ?? false).ToString().ToLowerInvariant());
        const zoomEnabled = true; // Enable zoom on planet selection

        let currentX = 550;
        let currentY = 120;
        let currentRotation = 0;
        let isTraveling = false;
        let activeOrbitPlanet = null;
        let orbitStartTime = null;
        let orbitRadius = 34;
        let travelStartTime = null;
        let travelDuration = 700;
        let travelFrom = { x: currentX, y: currentY };
        let travelTo = { x: currentX, y: currentY };
        let travelTargetPlanet = null;
        let orbitAnimationId = null;
        let travelAnimationId = null;
        let zoomAnimationId = null;
        let currentTooltipPlanet = null;
        let selectedPlanetId = null;

        function getToken() {
            return document.querySelector('#af-form input[name="__RequestVerificationToken"]')?.value || '';
        }

        function setActionState(enabled) {
            const disabled = !enabled || !isAuthenticated;
            taskMinutesInput.disabled = disabled;
            startSessionButton.disabled = disabled;

            if (!isAuthenticated) {
                actionsNote.textContent = 'Log in to start the timer.';
            } else if (!enabled) {
                actionsNote.textContent = 'Select a planet to enable the timer.';
            } else {
                actionsNote.textContent = '';
            }
        }
        function getOrbitRotationRad() {
            const transform = window.getComputedStyle(planetsOrbit).transform;
            if (!transform || transform === 'none') return 0;

            const match = transform.match(/matrix\(([^)]+)\)/);
            if (!match || !match[1]) return 0;

            const values = match[1].split(',').map(v => parseFloat(v.trim()));
            if (values.length < 2) return 0;

            return Math.atan2(values[1], values[0]);
        }

        function getActualPlanetPosition(planet) {
            const cx = parseFloat(planet.dataset.cx || '0');
            const cy = parseFloat(planet.dataset.cy || '0');
            const orbitRotation = getOrbitRotationRad();

            const dx = cx - centerX;
            const dy = cy - centerY;
            const distance = Math.sqrt(dx * dx + dy * dy);
            const angle = Math.atan2(dy, dx) + orbitRotation;

            return {
                x: centerX + distance * Math.cos(angle),
                y: centerY + distance * Math.sin(angle)
            };
        }

        function getOrbitRadius(planet) {
            const radiusFromData = parseFloat(planet.dataset.radius || '16');
            return Math.max(20, radiusFromData + 18);
        }

        function getOrbitAnchor(planet) {
            const center = getActualPlanetPosition(planet);
            const angle = -Math.PI / 3;
            const radius = getOrbitRadius(planet);

            return {
                x: center.x + radius * Math.cos(angle),
                y: center.y + radius * Math.sin(angle),
                angle
            };
        }

        function setRocketTransform(x, y, rotation) {
            currentX = x;
            currentY = y;
            currentRotation = rotation;
            rocket.setAttribute('transform', `translate(${x}, ${y}) rotate(${rotation})`);
        }

        function setSelectedPlanet(planet) {
            planetNodes.forEach(p => p.classList.remove('selected'));
            planet.classList.add('selected');

            const name = planet.dataset.name || 'Unknown';
            const type = planet.dataset.type || 'Unknown';
            const order = planet.dataset.order || '-';
            const description = (planet.dataset.description || '').trim();
            const distance = (planet.dataset.distance || '').trim();

            infoName.textContent = `#${order} ${name}`;
            infoType.textContent = `Type: ${type}`;
            infoDescription.textContent = description || 'No description provided for this planet.';
            infoDistance.textContent = distance
                ? `Distance from previous: ${distance}`
                : 'Distance from previous: not specified';

            // Show close button when planet is selected
            closePlanetPanel.style.display = 'block';
            selectedPlanetId = planet.dataset.id || null;
            planetActions.classList.remove('hidden');
            setActionState(true);
        }

        function showTooltip(planet, event) {
            currentTooltipPlanet = planet;

            const name = planet.dataset.name || 'Unknown';
            const type = planet.dataset.type || 'Unknown';
            const order = planet.dataset.order || '-';
            const description = (planet.dataset.description || '').trim() || 'No description provided.';
            const distance = (planet.dataset.distance || '').trim();

            planetTooltip.innerHTML = `
                <strong>#${order} ${name}</strong>
                <div>Type: ${type}</div>
                <div>${description}</div>
                <div class="tooltip-meta">${distance ? `Distance: ${distance}` : 'Distance: not specified'}</div>
            `;
            planetTooltip.style.display = 'block';
            updateTooltipPosition(event);
        }

        function updateTooltipPosition(event) {
            if (!currentTooltipPlanet) return;

            const rect = spaceStage.getBoundingClientRect();
            const tooltipWidth = planetTooltip.offsetWidth || 220;
            const tooltipHeight = planetTooltip.offsetHeight || 90;

            let left = event.clientX - rect.left + 16;
            let top = event.clientY - rect.top + 16;

            if (left + tooltipWidth > rect.width) left = event.clientX - rect.left - tooltipWidth - 16;
            if (top + tooltipHeight > rect.height) top = event.clientY - rect.top - tooltipHeight - 16;

            left = Math.max(10, left);
            top = Math.max(10, top);

            planetTooltip.style.left = `${left}px`;
            planetTooltip.style.top = `${top}px`;
        }

        function hideTooltip() {
            currentTooltipPlanet = null;
            planetTooltip.style.display = 'none';
        }

        function stopOrbit() {
            if (orbitAnimationId !== null) {
                cancelAnimationFrame(orbitAnimationId);
                orbitAnimationId = null;
            }
        }

        function stopTravel() {
            if (travelAnimationId !== null) {
                cancelAnimationFrame(travelAnimationId);
                travelAnimationId = null;
            }
        }

        function stopZoom() {
            if (zoomAnimationId !== null) {
                cancelAnimationFrame(zoomAnimationId);
                zoomAnimationId = null;
            }
        }

        function setViewBox(box) {
            svgElement.setAttribute(
                'viewBox',
                `${box.x.toFixed(2)} ${box.y.toFixed(2)} ${box.width.toFixed(2)} ${box.height.toFixed(2)}`
            );
        }

        function animateZoomToPlanet(planet) {
            stopZoom();

            const center = getActualPlanetPosition(planet);
            const planetRadius = getOrbitRadius(planet);
            const targetWidth = Math.max(360, planetRadius * 7.2);
            const targetHeight = Math.max(320, planetRadius * 5.8);

            const maxX = Math.max(0, 1020 - targetWidth);
            const maxY = Math.max(0, 820 - targetHeight);

            const target = {
                x: Math.min(Math.max(0, center.x - targetWidth / 2), maxX),
                y: Math.min(Math.max(0, center.y - targetHeight / 2), maxY),
                width: targetWidth,
                height: targetHeight
            };

            const start = { ...defaultViewBox };
            const duration = 900;
            let startTime = null;

            function easeInOut(t) {
                return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
            }

            function step(now) {
                if (!startTime) startTime = now;

                const progress = Math.min((now - startTime) / duration, 1);
                const eased = easeInOut(progress);
                const box = {
                    x: start.x + (target.x - start.x) * eased,
                    y: start.y + (target.y - start.y) * eased,
                    width: start.width + (target.width - start.width) * eased,
                    height: start.height + (target.height - start.height) * eased
                };

                setViewBox(box);

                if (progress < 1) {
                    zoomAnimationId = requestAnimationFrame(step);
                    return;
                }

                zoomAnimationId = null;
            }

            zoomAnimationId = requestAnimationFrame(step);
        }

        function resetZoom() {
            stopZoom();
            setViewBox(defaultViewBox);
        }

        function animateTravelToPlanet(planet) {
            stopTravel();
            stopOrbit();
            resetZoom();

            isTraveling = true;
            travelTargetPlanet = planet;
            travelStartTime = null;
            travelFrom = { x: currentX, y: currentY };

            const anchor = getOrbitAnchor(planet);
            travelTo = { x: anchor.x, y: anchor.y };

            const dx = travelTo.x - travelFrom.x;
            const dy = travelTo.y - travelFrom.y;
            const heading = Math.atan2(dy, dx) * 180 / Math.PI + 90;

            function step(now) {
                if (!travelStartTime) travelStartTime = now;

                const progress = Math.min((now - travelStartTime) / travelDuration, 1);
                const eased = progress < 0.5
                    ? 2 * progress * progress
                    : 1 - Math.pow(-2 * progress + 2, 2) / 2;

                const x = travelFrom.x + (travelTo.x - travelFrom.x) * eased;
                const y = travelFrom.y + (travelTo.y - travelFrom.y) * eased;
                const rotation = Math.atan2(y - currentY, x - currentX) * 180 / Math.PI + 90;
                setRocketTransform(x, y, Number.isFinite(rotation) ? rotation : heading);

                if (progress < 1) {
                    travelAnimationId = requestAnimationFrame(step);
                    return;
                }

                travelAnimationId = null;
                isTraveling = false;
                activeOrbitPlanet = travelTargetPlanet;
                orbitRadius = getOrbitRadius(activeOrbitPlanet);
                orbitStartTime = null;
                if (zoomEnabled) {
                    animateZoomToPlanet(activeOrbitPlanet);
                }

                // Start orbiting immediately after arrival
                startOrbitLoop();
            }

            travelAnimationId = requestAnimationFrame(step);
        }

        function startOrbitLoop() {
            stopOrbit();

            const orbitDuration = 2600;
            let lastFrameTime = null;

            function animateOrbit(now) {
                if (!activeOrbitPlanet) {
                    orbitAnimationId = null;
                    return;
                }

                // Initialize timing on first frame
                if (!orbitStartTime) {
                    orbitStartTime = now;
                }

                // Only animate orbit if we're not traveling
                if (!isTraveling) {
                    const elapsed = now - orbitStartTime;
                    const progress = (elapsed % orbitDuration) / orbitDuration;
                    const angle = progress * Math.PI * 2;
                    
                    const center = getActualPlanetPosition(activeOrbitPlanet);
                    const x = center.x + orbitRadius * Math.cos(angle);
                    const y = center.y + orbitRadius * Math.sin(angle);
                    
                    const nextAngle = angle + 0.03;
                    const nx = center.x + orbitRadius * Math.cos(nextAngle);
                    const ny = center.y + orbitRadius * Math.sin(nextAngle);
                    
                    const heading = Math.atan2(ny - y, nx - x) * 180 / Math.PI + 90;
                    setRocketTransform(x, y, Number.isFinite(heading) ? heading : 0);
                }

                orbitAnimationId = requestAnimationFrame(animateOrbit);
            }

            orbitAnimationId = requestAnimationFrame(animateOrbit);
        }

        function selectPlanet(planet) {
            setSelectedPlanet(planet);
            animateTravelToPlanet(planet);
        }

        function hidePlanetPanel() {
            planetNodes.forEach(p => p.classList.remove('selected'));
            closePlanetPanel.style.display = 'none';
            selectedPlanetId = null;
            setActionState(false);
            planetActions.classList.add('hidden');
            infoName.textContent = 'Choose a Planet';
            infoType.textContent = 'Click any planet to inspect it.';
            infoDescription.textContent = 'The rocket will fly to the selected planet and start circling around it.';
            infoDistance.textContent = '';
            resetZoom();
        }

        // Close panel button
        closePlanetPanel.addEventListener('click', hidePlanetPanel);

        function getSelectedPlanetInfo() {
            if (!selectedPlanetId) return null;

            const node = planetNodes.find(p => p.dataset.id === String(selectedPlanetId));
            if (!node) return null;

            return {
                id: node.dataset.id || '',
                name: node.dataset.name || '',
                type: node.dataset.type || '',
                description: (node.dataset.description || '').trim(),
                distance: (node.dataset.distance || '').trim()
            };
        }

        function storeActiveSessionPlanetInfo(sessionId, planetInfo) {
            if (!sessionId || !planetInfo) return;

            const payload = {
                sessionId: String(sessionId),
                planetInfo,
                storedAt: new Date().toISOString()
            };

            localStorage.setItem('activeSessionPlanet', JSON.stringify(payload));
        }

        async function openActiveSession() {
            const res = await fetch('/Session/GetActiveSession');
            if (!res.ok) return false;

            const data = await res.json().catch(() => null);
            if (!data || !data.hasActive || !data.sessionId) return false;

            const label = encodeURIComponent(data.label || '');
            const plannedSeconds = Number(data.plannedSeconds || 0);
            const remainingSeconds = Number(data.remainingSeconds || 0);
            const minutes = plannedSeconds > 0 ? Math.ceil(plannedSeconds / 60) : 25;

            window.location.href = `/Session?autostart=1&sessionId=${data.sessionId}&minutes=${minutes}&plannedSeconds=${plannedSeconds}&remainingSeconds=${remainingSeconds}&label=${label}`;
            return true;
        }

        async function startSessionFromPanel() {
            if (!selectedPlanetId) return;

            const minutes = parseInt(taskMinutesInput.value, 10) || 25;

            actionsNote.textContent = 'Starting timer...';

            const payload = {
                taskId: null,
                plannedMinutes: minutes
            };

            let sessionResponse = await fetch('/Session/Start', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify(payload)
            });

            if (sessionResponse.status === 409) {
                const replaceExisting = confirm('An active session already exists. Click OK to close it and start a new one, or Cancel to open the active session.');
                if (replaceExisting) {
                    sessionResponse = await fetch('/Session/Start', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': getToken()
                        },
                        body: JSON.stringify({
                            ...payload,
                            closeExisting: true
                        })
                    });
                } else {
                    const opened = await openActiveSession();
                    if (!opened) actionsNote.textContent = 'Could not open active session.';
                    return;
                }
            }

            const sessionPayload = await sessionResponse.json().catch(() => null);
            if (!sessionResponse.ok) {
                actionsNote.textContent = sessionPayload?.message || 'Could not start timer.';
                return;
            }

            const sessionId = sessionPayload?.sessionId;
            const label = encodeURIComponent(infoName.textContent || '');
            const planetInfo = getSelectedPlanetInfo();

            if (planetInfo && sessionId) {
                storeActiveSessionPlanetInfo(sessionId, planetInfo);
            }

            const planetQuery = planetInfo
                ? `&planetName=${encodeURIComponent(planetInfo.name)}&planetType=${encodeURIComponent(planetInfo.type)}&planetDescription=${encodeURIComponent(planetInfo.description)}&planetDistance=${encodeURIComponent(planetInfo.distance)}`
                : '';

            actionsNote.textContent = 'Timer started.';
            setTimeout(() => {
                window.location.href = `/Session?autostart=1&sessionId=${sessionId}&minutes=${minutes}&label=${label}${planetQuery}`;
            }, 350);
        }

        startSessionButton.addEventListener('click', startSessionFromPanel);
        setActionState(false);

        planetNodes.forEach(planet => {
            planet.addEventListener('click', () => selectPlanet(planet));
            planet.addEventListener('mouseenter', event => showTooltip(planet, event));
            planet.addEventListener('mousemove', event => updateTooltipPosition(event));
            planet.addEventListener('mouseleave', hideTooltip);
            planet.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    selectPlanet(planet);
                }
            });
        });

        const initialPlanet =
            planetNodes.find(p => (p.dataset.name || '').toLowerCase() === 'earth') ||
            planetNodes[0] ||
            null;

        if (initialPlanet) {
            setSelectedPlanet(initialPlanet);
            const initialPos = getActualPlanetPosition(initialPlanet);
            activeOrbitPlanet = initialPlanet;
            orbitRadius = getOrbitRadius(initialPlanet);
            setRocketTransform(initialPos.x + orbitRadius, initialPos.y, 90);
            resetZoom();
            startOrbitLoop();
        }

        const openFocusTimerBtn = document.getElementById('openFocusTimerBtn');
        if (openFocusTimerBtn) {
            openFocusTimerBtn.addEventListener('click', async (event) => {
                event.preventDefault();

                try {
                    const opened = await openActiveSession();
                    if (opened) return;
                } catch (err) {
                }

                window.location.href = '/Session';
            });
        }
    </script>
}
