@{
    ViewData["Title"] = "FocusSpace";
}

<div class="position-relative" style="height:80vh">
    <svg id="planet-visualization" width="100%" height="100%">

        <line x1="100" y1="100" x2="300" y2="300" stroke="#7c3aed" stroke-width="2" />
        <line x1="300" y1="300" x2="500" y2="150" stroke="#7c3aed" stroke-width="2" />
        <line x1="500" y1="150" x2="700" y2="400" stroke="#7c3aed" stroke-width="2" />

        <!-- Планети -->
        <g class="planet" data-name="Mercury" data-cx="100" data-cy="100">
            <circle cx="100" cy="100" r="30" fill="#7c3aed" />
            <text x="100" y="100" fill="#fff" text-anchor="middle" dominant-baseline="central" font-size="12">Mercury</text>
        </g>

        <g class="planet" data-name="Venus" data-cx="300" data-cy="300">
            <circle cx="300" cy="300" r="30" fill="#7c3aed" />
            <text x="300" y="300" fill="#fff" text-anchor="middle" dominant-baseline="central" font-size="12">Venus</text>
        </g>

        <g class="planet" data-name="Earth" data-cx="500" data-cy="150">
            <circle cx="500" cy="150" r="30" fill="#7c3aed" />
            <text x="500" y="150" fill="#fff" text-anchor="middle" dominant-baseline="central" font-size="12">Earth</text>
        </g>

        <g class="planet" data-name="Mars" data-cx="700" data-cy="400">
            <circle cx="700" cy="400" r="30" fill="#7c3aed" />
            <text x="700" y="400" fill="#fff" text-anchor="middle" dominant-baseline="central" font-size="12">Mars</text>
        </g>

        <!-- Ракета -->
        <polygon id="rocket" points="10,0 20,20 0,20"
                 fill="#ff5722"
                 transform="translate(90, 80)" />
    </svg>
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="text-center mt-4">
        <h2 class="mb-3">Welcome to FocusSpace</h2>
        <p class="text-muted mb-4">Track your focus sessions and explore the galaxy of productivity.</p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                Get Started
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                Log In
            </a>
        </div>
    </div>
}
else
{
    <div class="text-center mt-4">
        <h2 class="mb-3">Welcome back, @User.Identity.Name!</h2>
        <a asp-controller="Tasks" asp-action="Index" class="btn btn-primary btn-lg">
            Go to My Tasks
        </a>
    </div>
}

@section Scripts {
    <script>
        const rocket = document.getElementById('rocket');
        let currentX = 90, currentY = 80;

        document.querySelectorAll('.planet').forEach(planet => {
            planet.style.cursor = 'pointer';

            planet.addEventListener('mouseenter', () => {
                const cx = parseFloat(planet.dataset.cx) - 10;
                const cy = parseFloat(planet.dataset.cy) - 20;

                rocket.animate([
                    { transform: `translate(${currentX}px, ${currentY}px)` },
                    { transform: `translate(${cx}px, ${cy}px)` }
                ], {
                    duration: 800,
                    easing: 'ease-in-out',
                    fill: 'forwards'
                }).onfinish = () => {
                    currentX = cx;
                    currentY = cy;
                    rocket.setAttribute('transform', `translate(${cx}, ${cy})`);
                };
            });

            // Підсвічування при hover
            planet.addEventListener('mouseenter', () => {
                planet.querySelector('circle').setAttribute('fill', '#a78bfa');
            });
            planet.addEventListener('mouseleave', () => {
                planet.querySelector('circle').setAttribute('fill', '#7c3aed');
            });
        });
    </script>
}