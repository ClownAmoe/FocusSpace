@{
    ViewData["Title"] = "Registration Complete";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card p-5">
            <h2 style="font-size:56px;margin-bottom:16px">&#128231;</h2>
            <h4 class="mt-2 mb-2">Check your email</h4>
            <p class="text-muted">
                We sent a confirmation link to your email address.
                Please confirm your email, then wait for an admin to approve your account before logging in.
            </p>
            <p class="text-muted small">Didn't receive it? Check your spam folder.</p>
            <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary mt-3">
                Back to Login
            </a>
        </div>
    </div>
</div>