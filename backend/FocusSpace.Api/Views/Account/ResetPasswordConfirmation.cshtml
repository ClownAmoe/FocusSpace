@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card p-5">
            <h2 style="font-size:56px;margin-bottom:16px">&#10003;</h2>
            <h4 class="mt-2 mb-2">Password reset!</h4>
            <p class="text-muted">
                Your password has been updated. You can now log in with your new password.
            </p>
            <a asp-action="Login" asp-controller="Account" class="btn btn-primary mt-3">Log In</a>
        </div>
    </div>
</div>