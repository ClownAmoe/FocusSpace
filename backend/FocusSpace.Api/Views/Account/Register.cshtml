@model FocusSpace.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4">
            <h4 class="mb-1">Create Account</h4>
            <p class="text-muted small mb-4">Join FocusSpace and start your productivity journey.</p>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Username <span class="text-danger">*</span></label>
                    <input asp-for="Username" class="form-control" placeholder="e.g. john_doe" autocomplete="username" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password <span class="text-danger">*</span></label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="At least 8 characters" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                    <div class="form-text">Must include uppercase, lowercase and a digit.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Register</button>
            </form>

            <hr class="my-3" />
            <p class="text-center text-muted small mb-0">
                Already have an account?
                <a asp-action="Login" asp-controller="Account">Log in</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}