@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card p-5">
            <h2 style="font-size:56px;margin-bottom:16px">&#128236;</h2>
            <h4 class="mt-2 mb-2">Check your inbox</h4>
            <p class="text-muted">
                If an account with that email exists and is confirmed, we sent a password reset link.
                The link is valid for <strong>2 hours</strong>.
            </p>
            <p class="text-muted small">Don't see it? Check your spam or junk folder.</p>
            <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary mt-3">
                Back to Login
            </a>
        </div>
    </div>
</div>