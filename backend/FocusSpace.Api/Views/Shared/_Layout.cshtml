<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FocusSpace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #0f0f1a; color: #e0e0f0; }
        .navbar { background: #1a1a2e !important; }
        .navbar-brand { color: #a78bfa !important; font-weight: 700; letter-spacing: 1px; }
        .card { background: #1e1e35; border: 1px solid #2d2d50; }
        .btn-primary { background: #7c3aed; border-color: #7c3aed; }
        .btn-primary:hover { background: #6d28d9; border-color: #6d28d9; }
        .table { color: #e0e0f0; }
        .table-hover tbody tr:hover { background: #2a2a45; }
        a { color: #a78bfa; }
        a:hover { color: #c4b5fd; }
        .form-control { background: #12122a !important; color: #e0e0f0 !important; border-color: #3d3d60 !important; }
        .form-control:focus { border-color: #7c3aed !important; box-shadow: 0 0 0 .2rem rgba(124,58,237,.25) !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🚀 FocusSpace</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-light" asp-controller="Tasks" asp-action="Index">My Tasks</a>
            </div>
        </div>
    </nav>

    <div class="container">
        @if (TempData["Success"] is not null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    @* Render optional Scripts section defined by child views *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
