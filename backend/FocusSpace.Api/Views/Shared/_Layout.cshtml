<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FocusSpace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0f0f1a;
            color: #e0e0f0;
        }

        .navbar {
            background: #1a1a2e !important;
        }

        .navbar-brand {
            color: #a78bfa !important;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .card {
            background: #1e1e35;
            border: 1px solid #2d2d50;
        }

        .btn-primary {
            background: #7c3aed;
            border-color: #7c3aed;
        }

            .btn-primary:hover {
                background: #6d28d9;
                border-color: #6d28d9;
            }

        .table {
            color: #e0e0f0;
        }

        .table-hover tbody tr:hover {
            background: #2a2a45;
        }

        a {
            color: #a78bfa;
        }

            a:hover {
                color: #c4b5fd;
            }

        .form-control {
            background: #12122a !important;
            color: #e0e0f0 !important;
            border-color: #3d3d60 !important;
        }

            .form-control:focus {
                border-color: #7c3aed !important;
                box-shadow: 0 0 0 .2rem rgba(124,58,237,.25) !important;
            }

        .form-text {
            color: #888 !important;
        }

        .dropdown-menu {
            background: #1e1e35 !important;
            border-color: #2d2d50 !important;
        }

        .dropdown-item {
            color: #e0e0f0 !important;
        }

            .dropdown-item:hover {
                background: #2a2a45 !important;
            }

        .alert-info {
            background: #1a2a3a;
            border-color: #1e5a8a;
            color: #90caf9;
        }

        .alert-success {
            background: #1a2a1a;
            border-color: #2e7d32;
            color: #a5d6a7;
        }

        .alert-danger {
            background: #2a1a1a;
            border-color: #7d2e2e;
            color: #ef9a9a;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🚀 FocusSpace</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-1">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Tasks" asp-action="Index">
                                My Tasks
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" style="color:#fbbf24"
                                   asp-controller="Admin" asp-action="Index">
                                    Admin Panel
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light" href="#"
                               id="userDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger"
                                                style="background:transparent;border:none;width:100%;text-align:left;padding:8px 16px;cursor:pointer">
                                            Log Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Account" asp-action="Login">
                                Log In
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm ms-2"
                               asp-controller="Account" asp-action="Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <div class="container">

        @* Глобальні TempData повідомлення *@
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @success
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @error
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Info"] is string info)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @info
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>